<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/fondo_principal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Iniciar Sesión"
        android:textSize="32sp"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Email o nombre de usuario"
        android:inputType="text"
        android:textColor="@color/black"
        android:textColorHint="@color/texto_secundario"
        android:backgroundTint="@color/rojo_principal"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Contraseña"
        android:inputType="textPassword"
        android:textColor="@color/black"
        android:textColorHint="@color/texto_secundario"
        android:backgroundTint="@color/rojo_principal"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entrar"
        android:textSize="20sp"
        android:backgroundTint="@color/boton_negro"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnIrRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿No tienes cuenta? Regístrate"
        android:textSize="16sp"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:background="@android:color/transparent"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnInvitado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entrar como invitado"
        android:textSize="16sp"
        android:textColor="@color/texto_secundario"
        android:fontFamily="@font/knewave_regular"
        android:background="@android:color/transparent"
        android:padding="16dp"/>

</LinearLayout>