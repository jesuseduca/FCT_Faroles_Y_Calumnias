<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_principal"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Cómo se juega?"
            android:textSize="32sp"
            android:textColor="@color/rojo_principal"
            android:fontFamily="@font/knewave_regular"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="El objetivo"
            android:textSize="22sp"
            android:textColor="@color/rojo_principal"
            android:fontFamily="@font/black_and_white_picture"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uno de los jugadores es el adivino y no conoce la palabra secreta. El resto sí la conocen y deben hablar sobre ella sin revelarla. El adivino intenta descubrir quién miente."
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/sigmar"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Los turnos"
            android:textSize="22sp"
            android:textColor="@color/rojo_principal"
            android:fontFamily="@font/black_and_white_picture"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cada jugador tiene un turno para decir una pista o una frase sobre la palabra. El adivino escucha a todos y luego vota a quien cree que está mintiendo."
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/sigmar"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Las vidas"
            android:textSize="22sp"
            android:textColor="@color/rojo_principal"
            android:fontFamily="@font/black_and_white_picture"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cada jugador tiene 3 vidas. Si el adivino te vota y acierta, pierdes una vida. Cuando te quedas sin vidas quedas eliminado. El juego termina cuando solo quedan 2 jugadores."
            android:textSize="16sp"
            android:textColor="@color/black"
            android:fontFamily="@font/sigmar"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnCerrarInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Entendido"
            android:textSize="20sp"
            android:textColor="@color/rojo_principal"
            android:fontFamily="@font/knewave_regular"
            android:background="@drawable/boton_relieve"
            android:padding="16dp"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</ScrollView>