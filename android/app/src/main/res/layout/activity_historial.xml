<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/fondo_principal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Historial de partidas"
        android:textSize="32sp"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:layout_marginBottom="24dp"/>

    <ListView
        android:id="@+id/lvHistorial"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnVolverPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver"
        android:textSize="18sp"
        android:backgroundTint="#2A2A2A"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:padding="16dp"/>

</LinearLayout>