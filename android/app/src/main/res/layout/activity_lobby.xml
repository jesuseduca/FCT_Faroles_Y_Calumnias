<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/fondo_principal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sala de espera"
        android:textSize="32sp"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvCodigoSala"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Código: "
        android:textSize="18sp"
        android:textColor="@color/black"
        android:fontFamily="@font/sigmar"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jugadores en la sala"
        android:textSize="22sp"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/black_and_white_picture"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/lvJugadores"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="24dp"/>

    <Spinner
        android:id="@+id/spinnerMazos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnEmpezarPartida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Empezar partida"
        android:textSize="20sp"
        android:backgroundTint="#2A2A2A"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:padding="16dp"/>

</LinearLayout>