<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CEBCBD"
    tools:context=".MainActivity">

    <android.widget.TextView
        android:id="@+id/textView2"
        android:layout_width="372dp"
        android:layout_height="87dp"
        android:background="@drawable/fondo_titulo"
        android:fontFamily="@font/knewave_regular"
        android:text="Faroles y Calumnias"
        android:textAlignment="center"
        android:textColor="#BB3235"
        android:textSize="32sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.042" />

    <android.widget.Button
        android:id="@+id/botonEmpezar"
        android:layout_width="219dp"
        android:layout_height="206dp"
        android:layout_marginStart="47dp"
        android:layout_marginTop="400dp"
        android:layout_marginEnd="52dp"
        android:background="@drawable/boton_relieve"
        android:fontFamily="@font/knewave_regular"
        android:text="@string/empezar_partida"
        android:textColor="#BB3235"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.52"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="311dp"
        android:layout_height="419dp"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintBottom_toTopOf="@+id/botonEmpezar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/jonkler" />

</androidx.constraintlayout.widget.ConstraintLayout>