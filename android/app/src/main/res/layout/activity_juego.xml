<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/fondo_principal">

    <TextView
        android:id="@+id/tvTurno"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Toca dialogar"
        android:textSize="22sp"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:layout_marginBottom="4dp"/>


    <GridLayout
        android:id="@+id/gridPalabras"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jugadores"
        android:textSize="18sp"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/black_and_white_picture"
        android:layout_marginBottom="4dp"/>

    <ListView
        android:id="@+id/lvJugadoresVivos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnVotar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Votar"
        android:textSize="20sp"
        android:backgroundTint="#2A2A2A"
        android:textColor="@color/rojo_principal"
        android:fontFamily="@font/knewave_regular"
        android:padding="16dp" />

</LinearLayout>