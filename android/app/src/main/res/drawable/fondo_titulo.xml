<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradiente vertical en tonos gris oscuro -->
    <gradient
        android:startColor="#2A2A2A"
        android:endColor="#3E3E3E"
        android:angle="90" />

    <!-- Bordes redondeados -->
    <corners android:radius="30dp" />

    <!-- Sombra interna simulada con padding -->
    <padding
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="12dp" />

    <!-- Borde en gris más oscuro -->
    <stroke
        android:width="4dp"
        android:color="#1E1E1E" />

</shape>
